[0.734, "o", "\u001b[H\u001b[3;38;5;245m  Project Bluefin presents...\u001b[0m\u001b[K\r\n\u001b[K\r\n\u001b[38;5;39m╔══════════════════════════════════════════════════════════╗\u001b[0m\u001b[K\r\n\u001b[38;5;39m║\u001b[0m     \u001b[1;38;5;51mK N U C K L E\u001b[0m                                        \u001b[38;5;39m║\u001b[0m\u001b[K\r\n\u001b[38;5;39m╚══════════════════════════════════════════════════════════╝\u001b[0m\u001b[K\r\n  \u001b[38;5;75mhomelab ignition configurator\u001b[0m\u001b[K\r\n  \u001b[3;38;5;250mThe real thing, right from the CNCF. Legends will rise.\u001b[0m\u001b[K\r\n\u001b[K\r\n  \u001b[38;5;75mstable\u001b[0m\u001b[38;5;240m │ \u001b[0m\u001b[38;5;245mv4593.2.1\u001b[0m\u001b[38;5;240m │ \u001b[0m\u001b[38;5;245mlinux 6.12.87\u001b[0m\u001b[38;5;240m │ \u001b[0m\u001b[38;5;245msystemd 257.9\u001b[0m\u001b[38;5;240m  │  \u001b[0m\u001b[38;5;42m●\u001b[0m \u001b[38;5;42m●\u001b[0m \u001b[38;5;214m●\u001b[0m\u001b[K\r\n  \u001b[38;5;75m━━\u001b[0m\u001b[38;5;240m·\u001b[0m\u001b[38;5;75m━━\u001b[0m\u001b[38;5;240m·\u001b[0m\u001b[38;5;75m━━\u001b[0m\u001b[38;5;240m·\u001b[0m\u001b[38;5;75m━━\u001b[0m\u001b[38;5;240m·\u001b[0m\u001b[38;5;75m━━\u001b[0m\u001b[38;5;240m·\u001b[0m\u001b[38;5;75m━━\u001b[0m\u001b[38;5;240m·\u001b[0m\u001b[1;38;5;51m━━\u001b[0m\u001b[38;5;240m·\u001b[0m\u001b[38;5;240m──\u001b[0m\u001b[K\r\n\u001b[K\r\n\u001b[K\r\nUpdate Strategy\u001b[K\r\n\u001b[K\r\nChoose how Flatcar will handle OS updates:\u001b[K\r\n\u001b[K\r\n\u001b[1;38;5;170m▸ reboot (Recommended)\u001b[0m\u001b[K\r\n    Auto-update and reboot immediately when an update is applied.\u001b[K\r\n    Best for: single nodes, dev environments\u001b[K\r\n\u001b[K\r\n  off\u001b[K\r\n    Updates are downloaded but never applied automatically.\u001b[K\r\n    You must run 'update_engine_client -update' manually.\u001b[K\r\n    Best for: manually managed infrastructure\u001b[K\r\n\u001b[K\r\n  etcd-lock\u001b[K\r\n    Coordinates reboots with other nodes via etcd distributed lock.\u001b[K\r\n    Only one node reboots at a time in the cluster.\u001b[K\r\n    Best for: multi-node clusters running etcd\u001b[K\r\n\u001b[K\r\n\u001b[K\r\n                                                  \u001b[K\r\n\u001b[38;5;241m↑↓/jk navigate • enter confirm • esc back • q quit\u001b[0m\u001b[K\u001b[J\u001b[33;H"]
