[38;5;59mfilter\u001b[0m\u001b[38;5;59m • \u001b[0m\u001b[38;5;59m?\u001b[0m \u001b[38;5;59mmore\u001b[0m                   \u001b[K\r\n        ┌────────────────────────────────────────────────────┐\u001b[K\r\n        │ Version:  0.14.16                                  │\u001b[K\r\n        │ Category: AI / ML                                  │\u001b[K\r\n        │ Support:  Experimental                             │\u001b[K\r\n        │                                                    │\u001b[K\r\n        │ LlamaEdge provides a lightweight LLM inference     │\u001b[K\r\n        │ server running WebAssembly via WasmEdge. The       │\u001b[K\r\n        │ llamaedge and wasmedge sysext versions must match  │\u001b[K\r\n        │ exactly — llamaedge includes a WasmEdge plugin     │\u001b[K\r\n        │ that is version-specific. Does not start at boot.  │\u001b[K\r\n        │ Run with: wasmedge run                             │\u001b[K\r\n        │ /usr/lib/wasmedge/wasm/llama-api-server.wasm.      │\u001b[K\r\n\n        │ ! Requires the wasmedge sysext with an exactly     │\u001b[K\r\n        │ matching version — check bakery docs for the       │\u001b[K\r\n        │ required wasmedge version.                         │\u001b[K\r\n        │ ! Not automatically built in bakery CI — releases  │\u001b[K\r\n        │ may lag behind upstream.                           │\u001b[K\r\n        │ ! Does not start at boot — must be invoked         │\u001b[K\r\n        │ manually after provisioning.                       │\u001b[K\r\n\n\n\n\u001b[51;H"]
