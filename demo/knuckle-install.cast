[1.5, "o", "\u001b[H\r\n\r\n\r\n\r\n\r\n\r\n\r\n\u001b[38;2;68;71;89m \u001b[0m \u001b[38;2;189;147;249mHostname\u001b[0m                                                                      \r\r\n\u001b[38;2;68;71;89m \u001b[0m \u001b[38;2;241;250;140m> \u001b[0mflatcar                                                                     \r\r\n\r\n\u001b[38;2;68;71;89m\u2503\u001b[0m \u001b[38;2;189;147;249mTimezone\u001b[0m                                                                      \r\r\n\u001b[38;2;68;71;89m\u2503\u001b[0m \u001b[38;2;97;113;163me.g. America/New_York, Europe/Berlin\u001b[0m                                          \r\r\n\u001b[38;2;68;71;89m\u2503\u001b[0m \u001b[38;2;241;250;140m> \u001b[0mUTC\u001b[7;38;2;241;250;140m \u001b[0m                                                                        \r\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\u001b[38;2;97;97;97mshift+tab\u001b[0m \u001b[38;2;73;73;73mback\u001b[0m\u001b[38;2;60;60;60m \u2022 \u001b[0m\u001b[38;2;97;97;97menter\u001b[0m \u001b[38;2;73;73;73mnext\u001b[0m\u001b[K\u001b[24;H"]
[1.5, "o", "\u001b[H\r  \u001b[38;5;75m\u2501\u2501\u001b[0m\u001b[38;5;240m\u00b7\u001b[0m\u001b[38;5;75m\u2501\u2501\u001b[0m\u001b[38;5;240m\u00b7\u001b[0m\u001b[38;5;75m\u2501\u2501\u001b[0m\u001b[38;5;240m\u00b7\u001b[0m\u001b[38;5;75m\u2501\u2501\u001b[0m\u001b[38;5;240m\u00b7\u001b[0m\u001b[38;5;75m\u2501\u2501\u001b[0m\u001b[38;5;240m\u00b7\u001b[0m\u001b[38;5;75m\u2501\u2501\u001b[0m\u001b[38;5;240m\u00b7\u001b[0m\u001b[1;38;5;51m\u2501\u2501\u001b[0m\u001b[38;5;240m\u00b7\u001b[0m\u001b[38;5;240m\u2500\u2500\u001b[0m\u001b[K\r\r\n\u001b[K\r\r\n\u001b[K\r\r\nUpdate Strategy\u001b[K\r\r\n\u001b[K\r\r\nChoose how Flatcar will handle OS updates:\u001b[K\r\r\n\u001b[K\r\r\n\u001b[1;38;5;170m\u25b8 reboot (Recommended)\u001b[0m\u001b[K\r\r\n    Auto-update and reboot immediately when an update is applied.\u001b[K\r\r\n    Best for: single nodes, dev environments\u001b[K\r\r\n\u001b[K\r\r\n  off\u001b[K\r\r\n    Updates are downloaded but never applied automatically.\u001b[K\r\r\n    You must run 'update_engine_client -update' manually.\u001b[K\r\r\n    Best for: manually managed infrastructure\u001b[K\r\r\n\u001b[K\r\r\n  etcd-lock\u001b[K\r\r\n    Coordinates reboots with other nodes via etcd distributed lock.\u001b[K\r\r\n    Only one node reboots at a time in the cluster.\u001b[K\r\r\n    Best for: multi-node clusters running etcd\u001b[K\r\r\n\u001b[K\r\r\n\u001b[K\r\r\n                                                  \u001b[K\r\r\n\u001b[38;5;241m\u2191\u2193/jk navigate \u2022 enter confirm \u2022 esc back \u2022 q quit\u001b[0m\u001b[K\u001b[24;H"]
